{
  "name": "tailhub",
  "version": "0.1.0",
  "description": "Self-hosted artifact sync hub for private, local-first apps on your Tailscale network. Zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "author": "Alan Garcia",
  "homepage": "https://github.com/alnandr/tailhub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alnandr/tailhub.git",
    "directory": "packages/hub"
  },
  "bugs": {
    "url": "https://github.com/alnandr/tailhub/issues"
  },
  "keywords": [
    "tailscale",
    "tailnet",
    "sync",
    "local-first",
    "self-hosted",
    "artifact",
    "pwa",
    "backup",
    "offline-first"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "tailhub": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node build/postbuild.mjs",
    "test": "tsc -p tsconfig.test.json && node build/postbuild-test.mjs && node ../../scripts/run-node-tests.mjs dist-test/test",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0"
  }
}
