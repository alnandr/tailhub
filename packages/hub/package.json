{
  "name": "tailhub",
  "version": "0.1.0",
  "description": "Self-hosted artifact sync hub for private, local-first apps on your Tailscale network. Zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "tailhub": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node build/postbuild.mjs",
    "test": "tsc -p tsconfig.test.json && node build/postbuild-test.mjs && node --test \"dist-test/test/*.test.js\""
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0"
  }
}
